[tasks."opencode:deps:install"]
alias = "opodi"
description = "Install OpenCode local plugin dependencies"
run = '''
  set -eu
  cd "$HOME/.config/opencode"
  if command -v bun >/dev/null 2>&1; then
    bun install --frozen-lockfile
  else
    npm install
  fi
'''

[tasks."opencode:config:current"]
alias = "opos"
description = "Show current rendered OpenCode config"
run = '''
  set -eu
  bash "$HOME/.config/mise/scripts/run-node-task" "$HOME/.config/mise/scripts/opencode-tasks.mjs" config-current "$HOME/.config/opencode/opencode.json"
'''

[tasks."opencode:profile:current"]
description = "Show active OpenCode provider/model profile"
run = "mise run opencode:config:current"

[tasks."opencode:profile:set:work-openai"]
description = "Render OpenCode config for work OpenAI profile"
run = '''
  set -eu
  template=$(chezmoi source-path "$HOME/.config/opencode/opencode.json")
  chezmoi execute-template --file \
    --override-data '{"opencode":{"profile":"work-openai"}}' \
    "$template" > "$HOME/.config/opencode/opencode.json"
  mise run opencode:profile:current
'''

[tasks."opencode:profile:set:work-copilot"]
description = "Render OpenCode config for work GitHub Copilot profile"
run = '''
  set -eu
  template=$(chezmoi source-path "$HOME/.config/opencode/opencode.json")
  chezmoi execute-template --file \
    --override-data '{"opencode":{"profile":"work-copilot"}}' \
    "$template" > "$HOME/.config/opencode/opencode.json"
  mise run opencode:profile:current
'''

[tasks."opencode:profile:set:home-copilot"]
description = "Render OpenCode config for home GitHub Copilot profile"
run = '''
  set -eu
  template=$(chezmoi source-path "$HOME/.config/opencode/opencode.json")
  chezmoi execute-template --file \
    --override-data '{"opencode":{"profile":"home-copilot"}}' \
    "$template" > "$HOME/.config/opencode/opencode.json"
  mise run opencode:profile:current
'''

[tasks."opencode:profile:validate"]
description = "Validate all OpenCode profile renders as JSON"
run = '''
  set -eu
  template=$(chezmoi source-path "$HOME/.config/opencode/opencode.json")

  chezmoi execute-template --file \
    --override-data '{"opencode":{"profile":"work-openai"}}' \
    "$template" | bash "$HOME/.config/mise/scripts/run-node-task" "$HOME/.config/mise/scripts/opencode-tasks.mjs" validate-json

  chezmoi execute-template --file \
    --override-data '{"opencode":{"profile":"work-copilot"}}' \
    "$template" | bash "$HOME/.config/mise/scripts/run-node-task" "$HOME/.config/mise/scripts/opencode-tasks.mjs" validate-json

  chezmoi execute-template --file \
    --override-data '{"opencode":{"profile":"home-copilot"}}' \
    "$template" | bash "$HOME/.config/mise/scripts/run-node-task" "$HOME/.config/mise/scripts/opencode-tasks.mjs" validate-json

  echo "All OpenCode profiles render valid JSON"
'''

[tasks."opencode:models:validate"]
alias = "opomv"
description = "Validate canonical OpenCode template JSON for both machine modes"
run = '''
  set -eu
  template=$(chezmoi source-path "$HOME/.config/opencode/opencode.json")

  chezmoi execute-template --file --override-data '{"opencode":{"profile":"work-openai"}}' "$template" | bash "$HOME/.config/mise/scripts/run-node-task" "$HOME/.config/mise/scripts/opencode-tasks.mjs" validate-json
  chezmoi execute-template --file --override-data '{"opencode":{"profile":"work-copilot"}}' "$template" | bash "$HOME/.config/mise/scripts/run-node-task" "$HOME/.config/mise/scripts/opencode-tasks.mjs" validate-json
  chezmoi execute-template --file --override-data '{"opencode":{"profile":"home-copilot"}}' "$template" | bash "$HOME/.config/mise/scripts/run-node-task" "$HOME/.config/mise/scripts/opencode-tasks.mjs" validate-json

  echo "Canonical OpenCode template is valid JSON for all supported profiles"
'''

[tasks."opencode:models:refresh:matrix:openai"]
description = "Refresh the managed OpenAI model matrix artifact"
run = '''
  set -eu
  repo_root=$(git rev-parse --show-toplevel 2>/dev/null || true)
  script_path=""
  if [ -n "$repo_root" ] && [ -f "$repo_root/dot_agents/skills/verify-opencode-models/scripts/verify-models.mjs" ]; then
    script_path="$repo_root/dot_agents/skills/verify-opencode-models/scripts/verify-models.mjs"
  else
    script_path="$HOME/.agents/skills/verify-opencode-models/scripts/verify-models.mjs"
  fi
  bash "$HOME/.config/mise/scripts/run-node-task" "$script_path" refresh --provider openai
'''

[tasks."opencode:models:refresh:matrix:github-copilot"]
description = "Refresh the managed GitHub Copilot model matrix artifact"
run = '''
  set -eu
  repo_root=$(git rev-parse --show-toplevel 2>/dev/null || true)
  script_path=""
  if [ -n "$repo_root" ] && [ -f "$repo_root/dot_agents/skills/verify-opencode-models/scripts/verify-models.mjs" ]; then
    script_path="$repo_root/dot_agents/skills/verify-opencode-models/scripts/verify-models.mjs"
  else
    script_path="$HOME/.agents/skills/verify-opencode-models/scripts/verify-models.mjs"
  fi
  bash "$HOME/.config/mise/scripts/run-node-task" "$script_path" refresh --provider github-copilot
'''

[tasks."opencode:models:refresh:matrix:all"]
description = "Refresh all managed OpenCode model matrix artifacts"
run = [
  "mise run opencode:models:refresh:matrix:openai",
  "mise run opencode:models:refresh:matrix:github-copilot"
]

[tasks."opencode:models:list:openai"]
description = "List OpenAI models available through OpenCode"
run = "opencode models openai"

[tasks."opencode:models:list:github-copilot"]
description = "List GitHub Copilot models available through OpenCode"
run = "opencode models github-copilot"

