[tasks."opencode:deps:install"]
alias = "opodi"
description = "Install OpenCode local plugin dependencies"
run = '''
  set -eu
  cd "$HOME/.config/opencode"
  if command -v bun >/dev/null 2>&1; then
    bun install --frozen-lockfile
  else
    npm install
  fi
'''

[tasks."opencode:profile:copilot"]
alias = "opoc"
description = "Switch OpenCode to Copilot profile"
run = '''
  set -eu
  rm -f "$HOME/.config/opencode/oh-my-opencode.json" "$HOME/.config/opencode/oh-my-opencode.json".bak*
  cp "$HOME/.config/opencode/profiles/opencode.copilot.json" "$HOME/.config/opencode/opencode.json"
  cp "$HOME/.config/opencode/profiles/oh-my-openagent.copilot.json" "$HOME/.config/opencode/oh-my-openagent.json"
  echo "OpenCode profile switched to Copilot"
'''

[tasks."opencode:profile:openai"]
alias = "opoa"
description = "Switch OpenCode to OpenAI profile"
run = '''
  set -eu
  rm -f "$HOME/.config/opencode/oh-my-opencode.json" "$HOME/.config/opencode/oh-my-opencode.json".bak*
  cp "$HOME/.config/opencode/profiles/opencode.openai.json" "$HOME/.config/opencode/opencode.json"
  cp "$HOME/.config/opencode/profiles/oh-my-openagent.openai.json" "$HOME/.config/opencode/oh-my-openagent.json"
  echo "OpenCode profile switched to OpenAI"
'''

[tasks."opencode:profile:current"]
alias = "opos"
description = "Show current OpenCode profile models"
run = '''
  set -eu
  echo "opencode.json model:"
  if grep -q '"model"\s*:' "$HOME/.config/opencode/opencode.json"; then
    grep -E '"model"\s*:' "$HOME/.config/opencode/opencode.json" | head -n 1
  else
    echo "  (no top-level model; provider-based profile)"
  fi
  echo "oh-my-openagent sisyphus model:"
  if [ -f "$HOME/.config/opencode/oh-my-openagent.json" ]; then
    grep -A2 '"sisyphus"' "$HOME/.config/opencode/oh-my-openagent.json" | grep -E '"model"\s*:' | head -n 1
  else
    echo "  (missing; run mise opencode:profile:default)"
  fi
'''

[tasks."opencode:profile:default"]
alias = "opod"
description = "Switch OpenCode to default profile for this machine"
{{- if .work.enable }}
run = "mise opencode:profile:openai"
{{- else }}
run = "mise opencode:profile:copilot"
{{- end }}

[tasks."opencode:models:validate"]
alias = "opomv"
description = "Validate OpenCode template/profile JSON files"
run = '''
  set -eu
  repo_root=$(git rev-parse --show-toplevel)
  cd "$repo_root"

  expected_schema_base="https://raw.githubusercontent.com/code-yeongyu/oh-my-openagent/"
  grep -q "$expected_schema_base" dot_config/opencode/oh-my-openagent.json.tmpl
  grep -q "$expected_schema_base" dot_config/opencode/profiles/oh-my-openagent.openai.json.tmpl
  grep -q "$expected_schema_base" dot_config/opencode/profiles/oh-my-openagent.copilot.json.tmpl

  chezmoi execute-template < dot_config/opencode/opencode.json.tmpl | python -m json.tool >/dev/null
  chezmoi execute-template < dot_config/opencode/oh-my-openagent.json.tmpl | python -m json.tool >/dev/null

  chezmoi execute-template < dot_config/opencode/profiles/opencode.openai.json.tmpl | python -m json.tool >/dev/null
  chezmoi execute-template < dot_config/opencode/profiles/opencode.copilot.json.tmpl | python -m json.tool >/dev/null
  chezmoi execute-template < dot_config/opencode/profiles/oh-my-openagent.openai.json.tmpl | python -m json.tool >/dev/null
  chezmoi execute-template < dot_config/opencode/profiles/oh-my-openagent.copilot.json.tmpl | python -m json.tool >/dev/null

  echo "OpenCode model templates and profiles are valid JSON"
'''

[tasks."opencode:models:refresh:matrix:openai"]
description = "Refresh the managed OpenAI model matrix artifact"
run = '''
  set -eu
  repo_root=$(git rev-parse --show-toplevel 2>/dev/null || true)
  script_path=""
  if [ -n "$repo_root" ] && [ -f "$repo_root/dot_agents/skills/verify-opencode-models/scripts/verify-models.mjs" ]; then
    script_path="$repo_root/dot_agents/skills/verify-opencode-models/scripts/verify-models.mjs"
  else
    script_path="$HOME/.agents/skills/verify-opencode-models/scripts/verify-models.mjs"
  fi
  node "$script_path" refresh --provider openai
'''

[tasks."opencode:models:refresh:matrix:github-copilot"]
description = "Refresh the managed GitHub Copilot model matrix artifact"
run = '''
  set -eu
  repo_root=$(git rev-parse --show-toplevel 2>/dev/null || true)
