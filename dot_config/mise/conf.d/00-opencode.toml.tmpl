[tasks."opencode:plugins:validate"]
alias = "opopv"
description = "Validate OpenCode plugin allowlist and pinned sources"
run = '''
  set -eu
  repo_root=$(git rev-parse --show-toplevel)
  cd "$repo_root"

  bash "$HOME/.config/mise/scripts/run-node-task" "$HOME/.config/mise/scripts/opencode-tasks.mjs" validate-plugins

  grep -q 'superpowers@git+https://github.com/obra/superpowers.git#v5.0.5' .chezmoitemplates/opencode/plugins-openai.json.tmpl
  grep -q 'superpowers@git+https://github.com/obra/superpowers.git#v5.0.5' .chezmoitemplates/opencode/plugins-copilot.json.tmpl

  echo "OpenCode plugin sources are allowlisted and pinned"
'''

[tasks."opencode:setup"]
alias = "oposu"
description = "Install OpenCode tooling and validate the managed config"
run = [
  "mise opencode:deps:install",
  "mise opencode:plugins:validate",
  "mise opencode:models:validate"
]

[tools]
"npm:@github/copilot" = "latest"
"npm:opencode-ai" = "latest"
"npm:@openai/codex" = "latest"
