[tasks."opencode:deps:install"]
alias = "opodi"
description = "Install OpenCode local plugin dependencies"
run = '''
  set -eu
  cd "$HOME/.config/opencode"
  if command -v bun >/dev/null 2>&1; then
    bun install --frozen-lockfile
  else
    npm install
  fi
'''

[tasks."opencode:config:current"]
alias = "opos"
description = "Show current rendered OpenCode config"
run = '''
  set -eu
  python - <<'PY'
import json
from pathlib import Path

path = Path.home() / ".config/opencode/opencode.json"
if not path.exists():
    print("opencode.json missing; run chezmoi apply ~/.config/opencode/opencode.json")
    raise SystemExit(1)

data = json.loads(path.read_text())
print(f"model: {data.get('model', '(unset)')}")
print(f"small_model: {data.get('small_model', '(unset)')}")
providers = ", ".join(sorted(data.get('provider', {}).keys())) or "(none)"
print(f"providers: {providers}")
PY
'''

[tasks."opencode:profile:current"]
description = "Show active OpenCode provider/model profile"
run = "mise run opencode:config:current"

[tasks."opencode:profile:set:work-openai"]
description = "Render OpenCode config for work OpenAI profile"
run = '''
  set -eu
  chezmoi execute-template --file \
    --override-data '{"opencode":{"profile":"work-openai"}}' \
    dot_config/opencode/opencode.json.tmpl > "$HOME/.config/opencode/opencode.json"
  mise run opencode:profile:current
'''

[tasks."opencode:profile:set:work-copilot"]
