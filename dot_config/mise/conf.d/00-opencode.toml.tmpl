[tasks."opencode:deps:install"]
alias = "opodi"
description = "Install OpenCode local plugin dependencies"
run = '''
  set -eu
  cd "$HOME/.config/opencode"
  if command -v bun >/dev/null 2>&1; then
    bun install --frozen-lockfile
  else
    npm install
  fi
'''

[tasks."opencode:config:current"]
alias = "opos"
description = "Show current rendered OpenCode config"
run = '''
  set -eu
  bash "$HOME/.config/mise/scripts/run-node-task" "$HOME/.config/mise/scripts/opencode-tasks.mjs" config-current "$HOME/.config/opencode/opencode.json"
'''

[tasks."opencode:profile:current"]
description = "Show active OpenCode provider/model profile"
run = "mise run opencode:config:current"

[tasks."opencode:profile:set:work-openai"]
description = "Render OpenCode config for work OpenAI profile"
run = '''
  set -eu
  template=$(chezmoi source-path "$HOME/.config/opencode/opencode.json")
  chezmoi execute-template --file \
    --override-data '{"opencode":{"profile":"work-openai"}}' \
    "$template" > "$HOME/.config/opencode/opencode.json"
  mise run opencode:profile:current
'''

[tasks."opencode:profile:set:work-copilot"]
description = "Render OpenCode config for work GitHub Copilot profile"
run = '''
  set -eu
  template=$(chezmoi source-path "$HOME/.config/opencode/opencode.json")
  chezmoi execute-template --file \
    --override-data '{"opencode":{"profile":"work-copilot"}}' \
    "$template" > "$HOME/.config/opencode/opencode.json"
  mise run opencode:profile:current
'''

[tasks."opencode:profile:set:home-copilot"]
description = "Render OpenCode config for home GitHub Copilot profile"
run = '''
  set -eu
  template=$(chezmoi source-path "$HOME/.config/opencode/opencode.json")
  chezmoi execute-template --file \
    --override-data '{"opencode":{"profile":"home-copilot"}}' \
    "$template" > "$HOME/.config/opencode/opencode.json"
  mise run opencode:profile:current
'''

[tasks."opencode:profile:validate"]
description = "Validate all OpenCode profile renders as JSON"
run = '''
  set -eu
  template=$(chezmoi source-path "$HOME/.config/opencode/opencode.json")

  chezmoi execute-template --file \
    --override-data '{"opencode":{"profile":"work-openai"}}' \
    "$template" | bash "$HOME/.config/mise/scripts/run-node-task" "$HOME/.config/mise/scripts/opencode-tasks.mjs" validate-json

  chezmoi execute-template --file \
    --override-data '{"opencode":{"profile":"work-copilot"}}' \
    "$template" | bash "$HOME/.config/mise/scripts/run-node-task" "$HOME/.config/mise/scripts/opencode-tasks.mjs" validate-json

  chezmoi execute-template --file \
    --override-data '{"opencode":{"profile":"home-copilot"}}' \
    "$template" | bash "$HOME/.config/mise/scripts/run-node-task" "$HOME/.config/mise/scripts/opencode-tasks.mjs" validate-json

  echo "All OpenCode profiles render valid JSON"
'''

[tasks."opencode:models:validate"]
alias = "opomv"
description = "Validate canonical OpenCode template JSON for both machine modes"
run = '''
  set -eu
  template=$(chezmoi source-path "$HOME/.config/opencode/opencode.json")

  chezmoi execute-template --file --override-data '{"opencode":{"profile":"work-openai"}}' "$template" | bash "$HOME/.config/mise/scripts/run-node-task" "$HOME/.config/mise/scripts/opencode-tasks.mjs" validate-json
  chezmoi execute-template --file --override-data '{"opencode":{"profile":"work-copilot"}}' "$template" | bash "$HOME/.config/mise/scripts/run-node-task" "$HOME/.config/mise/scripts/opencode-tasks.mjs" validate-json
  chezmoi execute-template --file --override-data '{"opencode":{"profile":"home-copilot"}}' "$template" | bash "$HOME/.config/mise/scripts/run-node-task" "$HOME/.config/mise/scripts/opencode-tasks.mjs" validate-json

  echo "Canonical OpenCode template is valid JSON for all supported profiles"
'''

[tasks."opencode:models:refresh:matrix:openai"]
description = "Refresh the managed OpenAI model matrix artifact"
run = '''
  set -eu
  repo_root=$(git rev-parse --show-toplevel 2>/dev/null || true)
  script_path=""
  if [ -n "$repo_root" ] && [ -f "$repo_root/dot_agents/skills/verify-opencode-models/scripts/verify-models.mjs" ]; then
    script_path="$repo_root/dot_agents/skills/verify-opencode-models/scripts/verify-models.mjs"
  else
    script_path="$HOME/.agents/skills/verify-opencode-models/scripts/verify-models.mjs"
  fi
  bash "$HOME/.config/mise/scripts/run-node-task" "$script_path" refresh --provider openai
'''

[tasks."opencode:models:refresh:matrix:github-copilot"]
description = "Refresh the managed GitHub Copilot model matrix artifact"
run = '''
  set -eu
  repo_root=$(git rev-parse --show-toplevel 2>/dev/null || true)
  script_path=""
  if [ -n "$repo_root" ] && [ -f "$repo_root/dot_agents/skills/verify-opencode-models/scripts/verify-models.mjs" ]; then
    script_path="$repo_root/dot_agents/skills/verify-opencode-models/scripts/verify-models.mjs"
  else
    script_path="$HOME/.agents/skills/verify-opencode-models/scripts/verify-models.mjs"
  fi
  bash "$HOME/.config/mise/scripts/run-node-task" "$script_path" refresh --provider github-copilot
'''

[tasks."opencode:models:refresh:matrix:all"]
description = "Refresh all managed OpenCode model matrix artifacts"
run = [
  "mise run opencode:models:refresh:matrix:openai",
  "mise run opencode:models:refresh:matrix:github-copilot"
]

[tasks."opencode:models:list:openai"]
description = "List OpenAI models available through OpenCode"
run = "opencode models openai"

[tasks."opencode:models:list:github-copilot"]
description = "List GitHub Copilot models available through OpenCode"
run = "opencode models github-copilot"

[tasks."opencode:models:verify:openai"]
description = "Smoke-test OpenAI models through OpenCode"
run = '''
  set -eu
  repo_root=$(git rev-parse --show-toplevel 2>/dev/null || true)
  script_path=""
  if [ -n "$repo_root" ] && [ -f "$repo_root/dot_agents/skills/verify-opencode-models/scripts/verify-models.mjs" ]; then
    script_path="$repo_root/dot_agents/skills/verify-opencode-models/scripts/verify-models.mjs"
  else
    script_path="$HOME/.agents/skills/verify-opencode-models/scripts/verify-models.mjs"
  fi
  bash "$HOME/.config/mise/scripts/run-node-task" "$script_path" verify --provider openai
'''

[tasks."opencode:models:verify:github-copilot"]
description = "Smoke-test GitHub Copilot models through OpenCode"
run = '''
  set -eu
  repo_root=$(git rev-parse --show-toplevel 2>/dev/null || true)
  script_path=""
  if [ -n "$repo_root" ] && [ -f "$repo_root/dot_agents/skills/verify-opencode-models/scripts/verify-models.mjs" ]; then
    script_path="$repo_root/dot_agents/skills/verify-opencode-models/scripts/verify-models.mjs"
  else
    script_path="$HOME/.agents/skills/verify-opencode-models/scripts/verify-models.mjs"
  fi
  bash "$HOME/.config/mise/scripts/run-node-task" "$script_path" verify --provider github-copilot
'''

[tasks."opencode:models:verify:all"]
description = "Smoke-test OpenCode provider models through OpenCode"
run = [
  "mise run opencode:models:verify:openai",
  "mise run opencode:models:verify:github-copilot"
]

[tasks."opencode:models:recommend:openai"]
description = "Recommend OpenAI routing tiers from verified model results"
run = '''
  set -eu
  repo_root=$(git rev-parse --show-toplevel 2>/dev/null || true)
  script_path=""
  if [ -n "$repo_root" ] && [ -f "$repo_root/dot_agents/skills/verify-opencode-models/scripts/verify-models.mjs" ]; then
    script_path="$repo_root/dot_agents/skills/verify-opencode-models/scripts/verify-models.mjs"
  else
    script_path="$HOME/.agents/skills/verify-opencode-models/scripts/verify-models.mjs"
  fi
  bash "$HOME/.config/mise/scripts/run-node-task" "$script_path" recommend --provider openai
'''

[tasks."opencode:models:recommend:github-copilot"]
description = "Recommend GitHub Copilot routing tiers from verified model results"
run = '''
  set -eu
  repo_root=$(git rev-parse --show-toplevel 2>/dev/null || true)
  script_path=""
  if [ -n "$repo_root" ] && [ -f "$repo_root/dot_agents/skills/verify-opencode-models/scripts/verify-models.mjs" ]; then
    script_path="$repo_root/dot_agents/skills/verify-opencode-models/scripts/verify-models.mjs"
  else
    script_path="$HOME/.agents/skills/verify-opencode-models/scripts/verify-models.mjs"
  fi
  bash "$HOME/.config/mise/scripts/run-node-task" "$script_path" recommend --provider github-copilot
'''

[tasks."opencode:models:recommend:all"]
description = "Recommend routing tiers for all OpenCode provider models"
run = [
  "mise run opencode:models:recommend:openai",
  "mise run opencode:models:recommend:github-copilot"
]

[tasks."opencode:models:apply:work-openai"]
description = "Render OpenCode config with the work OpenAI profile"
run = "mise run opencode:profile:set:work-openai"

[tasks."opencode:models:apply:work-copilot"]
description = "Render OpenCode config with the work Copilot profile"
run = "mise run opencode:profile:set:work-copilot"

[tasks."opencode:models:apply:home-copilot"]
description = "Render OpenCode config with the home Copilot profile"
run = "mise run opencode:profile:set:home-copilot"

[tasks."opencode:models:apply:all"]
description = "Validate all model profile renders after template updates"
run = [
  "mise run opencode:models:apply:work-openai",
  "mise run opencode:models:apply:work-copilot",
  "mise run opencode:models:apply:home-copilot",
  "mise run opencode:models:validate"
]

[tasks."opencode:models:preflight"]
alias = "opomp"
description = "Preflight model routing: refresh, verify, recommend, validate"
run = [
  "mise run opencode:models:refresh:matrix:all",
  "mise run opencode:models:verify:all",
  "mise run opencode:models:recommend:all",
  "mise run opencode:models:validate"
]

[tasks."opencode:models:update:all"]
description = "Refresh/verify/recommend then apply all rendered profiles"
run = [
  "mise run opencode:models:preflight",
  "mise run opencode:models:apply:all"
]

[tasks."opencode:models:test"]
description = "Run offline tests for model verifier and profile routing logic"
run = '''
  set -eu
  node --test \
    dot_agents/skills/verify-opencode-models/scripts/verify-models.test.mjs \
    dot_agents/skills/verify-opencode-models/scripts/verify-models-cli.test.mjs \
    dot_config/mise/scripts/opencode-profile-routing.test.mjs
'''

[tasks."opencode:plugins:validate"]
alias = "opopv"
description = "Validate OpenCode plugin allowlist and pinned sources"
run = '''
  set -eu
  repo_root=$(git rev-parse --show-toplevel)
  cd "$repo_root"

  bash "$HOME/.config/mise/scripts/run-node-task" "$HOME/.config/mise/scripts/opencode-tasks.mjs" validate-plugins

  grep -q 'superpowers@git+https://github.com/obra/superpowers.git#v5.0.5' .chezmoitemplates/opencode/plugins-openai.json.tmpl
  grep -q 'superpowers@git+https://github.com/obra/superpowers.git#v5.0.5' .chezmoitemplates/opencode/plugins-copilot.json.tmpl

  echo "OpenCode plugin sources are allowlisted and pinned"
'''

[tasks."opencode:setup"]
alias = "oposu"
description = "Install OpenCode tooling and validate the managed config"
run = [
  "mise opencode:deps:install",
  "mise opencode:plugins:validate",
  "mise opencode:models:validate"
]

[tools]
"npm:@github/copilot" = "latest"
"npm:@openai/codex" = "latest"

[tools."npm:opencode-ai"]
version = "latest"
postinstall = '''
set -eu
if [ -f "$MISE_TOOL_INSTALL_PATH/node_modules/opencode-ai/postinstall.mjs" ]; then
  cd "$MISE_TOOL_INSTALL_PATH/node_modules/opencode-ai"
elif [ -f "$MISE_TOOL_INSTALL_PATH/lib/node_modules/opencode-ai/postinstall.mjs" ]; then
  cd "$MISE_TOOL_INSTALL_PATH/lib/node_modules/opencode-ai"
elif [ -f "$MISE_TOOL_INSTALL_PATH/postinstall.mjs" ]; then
  cd "$MISE_TOOL_INSTALL_PATH"
else
  echo "Could not find opencode-ai postinstall.mjs under $MISE_TOOL_INSTALL_PATH"
  find "$MISE_TOOL_INSTALL_PATH" -name postinstall.mjs -maxdepth 5 || true
  exit 1
fi
node postinstall.mjs
mise reshim
'''

[settings]
npm.package_manager = "npm"
