[tasks."opencode:profile:validate"]
description = "Validate all OpenCode profile renders as JSON"
run = '''
  set -eu

  chezmoi execute-template --file \
    --override-data '{"opencode":{"profile":"work-openai"}}' \
    dot_config/opencode/opencode.json.tmpl | python -m json.tool >/dev/null

  chezmoi execute-template --file \
    --override-data '{"opencode":{"profile":"work-copilot"}}' \
    dot_config/opencode/opencode.json.tmpl | python -m json.tool >/dev/null

  chezmoi execute-template --file \
    --override-data '{"opencode":{"profile":"home-copilot"}}' \
    dot_config/opencode/opencode.json.tmpl | python -m json.tool >/dev/null

  echo "All OpenCode profiles render valid JSON"
'''

[tasks."opencode:models:validate"]
alias = "opomv"
description = "Validate canonical OpenCode template JSON for both machine modes"
run = '''
  set -eu
  repo_root=$(git rev-parse --show-toplevel)
  cd "$repo_root"

  chezmoi execute-template --file --override-data '{"opencode":{"profile":"work-openai"}}' dot_config/opencode/opencode.json.tmpl | python -m json.tool >/dev/null
  chezmoi execute-template --file --override-data '{"opencode":{"profile":"work-copilot"}}' dot_config/opencode/opencode.json.tmpl | python -m json.tool >/dev/null
  chezmoi execute-template --file --override-data '{"opencode":{"profile":"home-copilot"}}' dot_config/opencode/opencode.json.tmpl | python -m json.tool >/dev/null

  echo "Canonical OpenCode template is valid JSON for all supported profiles"
'''

[tasks."opencode:models:refresh:matrix:openai"]
description = "Refresh the managed OpenAI model matrix artifact"
run = '''
  set -eu
  repo_root=$(git rev-parse --show-toplevel 2>/dev/null || true)
  script_path=""
  if [ -n "$repo_root" ] && [ -f "$repo_root/dot_agents/skills/verify-opencode-models/scripts/verify-models.mjs" ]; then
    script_path="$repo_root/dot_agents/skills/verify-opencode-models/scripts/verify-models.mjs"
  else
    script_path="$HOME/.agents/skills/verify-opencode-models/scripts/verify-models.mjs"
  fi
  node "$script_path" refresh --provider openai
'''

