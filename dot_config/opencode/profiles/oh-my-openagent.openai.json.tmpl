    "multimodal-looker": {
      "model": "openai/gpt-5.4"
    }
  },
  "categories": {
    "ultrabrain": {
      "model": "openai/gpt-5.5",
      "reasoningEffort": "high",
      "textVerbosity": "medium",
      "description": "Deep architecture and complex reasoning."
    },
    "deep": {
      "model": "openai/gpt-5.4",
      "reasoningEffort": "high",
      "textVerbosity": "medium",
      "description": "Implementation-oriented deep work / multi-step coding."
    },
    "quick": {
      "model": "openai/gpt-5.4-mini",
      "reasoningEffort": "low",
      "textVerbosity": "low",
      "description": "Small fixes, quick edits, straightforward changes."
    },
    "unspecified-low": {
      "model": "openai/gpt-5.4-mini",
      "reasoningEffort": "medium",
      "textVerbosity": "low",
      "description": "General-purpose default when no other category fits."
    },
    "visual-engineering": {
      "model": "openai/gpt-5.4",
      "reasoningEffort": "medium",
      "textVerbosity": "high",
      "description": "UI/UX, styling, visual consistency, frontend design reviews."
    },
    "documentation": {
      "model": "openai/gpt-5.4-mini",
      "reasoningEffort": "medium",
      "textVerbosity": "high",
      "description": "Docs, ADRs, release notes, README updates, and writing tasks."
    },
    "librarian": {
      "model": "openai/gpt-5.4-mini",
      "reasoningEffort": "medium",
      "textVerbosity": "medium",
      "description": "Codebase exploration + explaining findings with citations/paths."
    },
    "multimodal": {
      "model": "openai/gpt-5.4",
      "reasoningEffort": "medium",
      "textVerbosity": "high",
      "description": "Image + UI screenshot analysis, visual debugging, multimodal review."
    }
  },
  "_migrations": [
    "model-version:openai/gpt-5.3-codex->openai/gpt-5.4",
    "model-version:openai/gpt-5.3-codex->openai/gpt-5.4",
    "model-version:openai/gpt-5.3-codex->openai/gpt-5.4",
