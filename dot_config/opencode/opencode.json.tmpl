{
  "permission": {
    "*": "allow",
    "read": {
      "*": "allow",
      "*.env": "ask",
      "*.env.*": "ask",
      "*.env.local": "ask",
      "*.pem": "deny",
      "*.key": "deny",
      "*.p12": "deny",
      "*.pfx": "deny",
      "*.jks": "deny",
      "*credentials*": "deny",
      "*secret*": "ask",
      "*.keystore": "deny",
      ".git/config": "ask",
      ".git/config.*": "ask",
      "**/secrets/**": "ask",
      "**/private/**": "deny",
      "**/.aws/**": "deny",
      "**/.aws/config": "ask",
      "**/.ssh/**": "deny",
      "**/.ssh/config": "ask",
      "**/.gnupg/**": "deny",
      "*docker-compose*.yml": "ask",
      "$HOME/.kube/**": "deny",
      "$HOME/.kube/agent-kubeconfig": "allow"
    },
    "edit": {
      "*": "allow",
      "*.env": "ask",
      "*.env.*": "ask",
      "*.env.local": "ask",
      "*.pem": "deny",
      "*.key": "deny",
      "*.p12": "deny",
      "*.pfx": "deny",
      "*.jks": "deny",
      "*credentials*": "deny",
      "*secret*": "ask",
      "*.keystore": "deny",
      ".git/config": "ask",
      ".git/config.*": "ask",
      "**/secrets/**": "ask",
      "**/private/**": "deny",
      "**/.aws/**": "deny",
      "**/.aws/config": "ask",
      "**/.ssh/**": "deny",
      "**/.ssh/config": "ask",
      "**/.gnupg/**": "deny",
      "*docker-compose*.yml": "ask",
      "$HOME/.kube/**": "deny",
      "$HOME/.kube/agent-kubeconfig": "allow"
    },
    "bash": {
      "*": "allow",
      "git status *": "allow",
      "git diff *": "allow",
      "git log *": "allow",
      "git branch *": "allow",
      "grep *": "allow",
      "cat *.env*": "deny",
      "cat *secret*": "deny",
      "cat *credential*": "deny",
      "cat *.pem": "deny",
      "cat *.key": "deny",
      "printenv *": "deny",
      "env": "deny",
      "export *": "deny",
      "echo $*": "deny",
      "curl *": "ask",
      "wget *": "ask",
      "rm -rf *": "deny",
      "rm -r *": "deny",
      "mise env": "deny",
      "mise env *": "deny",
      "k9s*": "deny",
      "KUBECONFIG=$HOME/.kube/agent-kubeconfig k9s*": "allow",
      "kubectl*": "deny",
      "KUBECONFIG=$HOME/.kube/agent-kubeconfig kubectl*": "allow"
    },
    "zsh": {
      "*": "allow",
      "git status *": "allow",
      "git diff *": "allow",
      "git log *": "allow",
      "git branch *": "allow",
      "grep *": "allow",
      "cat *.env*": "deny",
      "cat *secret*": "deny",
      "cat *credential*": "deny",
      "cat *.pem": "deny",
      "cat *.key": "deny",
      "printenv *": "deny",
      "env": "deny",
      "export *": "deny",
      "echo $*": "deny",
      "curl *": "ask",
      "wget *": "ask",
      "rm -rf *": "deny",
      "rm -r *": "deny",
      "mise env": "deny",
      "mise env *": "deny",
      "k9s*": "deny",
      "KUBECONFIG=$HOME/.kube/agent-kubeconfig k9s*": "allow",
      "kubectl*": "deny",
      "KUBECONFIG=$HOME/.kube/agent-kubeconfig kubectl*": "allow"
    },
    "webfetch": "allow",
    "external_directory": "ask"
  },
{{- if .work.enable }}
  "plugin": [
    "oh-my-opencode",
    "opencode-openai-codex-auth"
  ],
  "model": "openai/gpt-5.3-codex",
  "small_model": "openai/gpt-5.1-codex-mini",
  "provider": {
    "openai": {
      "name": "OpenAI",
      "options": {
        "reasoningEffort": "medium",
        "reasoningSummary": "auto",
        "textVerbosity": "low",
        "include": ["reasoning.encrypted_content"],
        "store": false
      },
      "models": {
        "gpt-5.3-codex": {
          "name": "GPT 5.3 Codex (OAuth)",
          "limit": {
            "context": 272000,
            "output": 128000
          },
          "modalities": {
            "input": ["text", "image"],
            "output": ["text"]
          },
          "variants": {
            "low": {
              "reasoningEffort": "low",
              "reasoningSummary": "auto",
              "textVerbosity": "low"
            },
            "medium": {
              "reasoningEffort": "medium",
              "reasoningSummary": "auto",
              "textVerbosity": "low"
            },
            "high": {
              "reasoningEffort": "high",
              "reasoningSummary": "detailed",
              "textVerbosity": "medium"
            }
          }
        },
        "gpt-5.4": {
