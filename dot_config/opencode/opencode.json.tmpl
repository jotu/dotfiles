{{- $profile := "home-copilot" -}}
{{- if and (hasKey . "opencode") (hasKey .opencode "profile") .opencode.profile -}}
  {{- $profile = .opencode.profile -}}
{{- else if .work.enable -}}
  {{- $profile = "work-openai" -}}
{{- end -}}
{{- $copilotFlagship := "github-copilot/claude-opus-4.6" -}}
{{- $copilotCoding := "github-copilot/gpt-5.4" -}}
{{- $copilotHelper := "github-copilot/gpt-5.4-mini" -}}
{{- if eq $profile "work-copilot" -}}
  {{- $copilotFlagship = "github-copilot/gemini-3.1-pro-preview" -}}
  {{- $copilotCoding = "github-copilot/gpt-5.4" -}}
  {{- $copilotHelper = "github-copilot/gpt-5.4-mini" -}}
{{- else if eq $profile "home-copilot" -}}
  {{- $copilotFlagship = "github-copilot/gemini-2.5-pro" -}}
  {{- $copilotCoding = "github-copilot/gpt-5.3-codex" -}}
  {{- $copilotHelper = "github-copilot/gemini-3.5-flash" -}}
{{- end -}}
{
  "permission": {{ includeTemplate ".chezmoitemplates/opencode/permission.json.tmpl" }},
{{- if eq $profile "work-openai" }}
  "plugin": {{ includeTemplate ".chezmoitemplates/opencode/plugins-openai.json.tmpl" }},
  "model": "openai/gpt-5.4",
  "small_model": "openai/gpt-5.4-mini",
  "agent": {
    "plan": { "model": "openai/gpt-5.5" },
    "orchestrator": { "model": "openai/gpt-5.5" },
    "reviewer": { "model": "openai/gpt-5.5" },
    "architect": { "model": "openai/gpt-5.5" },
    "ai-workflow-engineer": { "model": "openai/gpt-5.5" },
    "oracle": { "model": "openai/gpt-5.5" },
    "security-engineer": { "model": "openai/gpt-5.5" },
    "ultrabrain": { "model": "openai/gpt-5.5" },

    "build": { "model": "openai/gpt-5.4" },
    "platform-engineer": { "model": "openai/gpt-5.5" },
    "developer-platform-engineer": { "model": "openai/gpt-5.4" },
    "builder": { "model": "openai/gpt-5.4" },
    "delivery-engineer": { "model": "openai/gpt-5.4" },
    "observability-engineer": { "model": "openai/gpt-5.5" },
    "explore": { "model": "openai/gpt-5.4" },
    "deep": { "model": "openai/gpt-5.4" },

    "frontend-ui-ux-engineer": { "model": "openai/gpt-5.4-fast" },
    "multimodal-looker": { "model": "openai/gpt-5.4-fast" },
    "visual-engineering": { "model": "openai/gpt-5.4-fast" },
    "multimodal": { "model": "openai/gpt-5.4-fast" },

    "librarian": { "model": "openai/gpt-5.4-mini" },
    "document-writer": { "model": "openai/gpt-5.4-mini" },
    "quick": { "model": "openai/gpt-5.4-mini" },
    "unspecified-low": { "model": "openai/gpt-5.4-mini" },
    "documentation": { "model": "openai/gpt-5.4-mini" }
  },
  "provider": {
    "openai": {
      "name": "OpenAI",
      "options": {
        "reasoningEffort": "medium",
        "reasoningSummary": "auto",
        "textVerbosity": "low",
        "include": ["reasoning.encrypted_content"],
        "store": false
      },
      "models": {
        "gpt-5.4": {
          "name": "GPT 5.4 (allowlisted)"
        },
        "gpt-5.4-fast": {
          "name": "GPT 5.4 Fast (allowlisted)"
        },
        "gpt-5.4-mini": {
          "name": "GPT 5.4 Mini (allowlisted)"
        },
        "gpt-5.5": {
          "name": "GPT 5.5 (allowlisted)"
        }
      }
    },
    "github-copilot": {
      "name": "GitHub Copilot",
      "models": {
        "claude-haiku-4.5": {
          "options": {
            "textVerbosity": "low"
          },
          "variants": {
            "low": {
              "textVerbosity": "low"
            },
            "medium": {
              "textVerbosity": "medium"
            }
          }
        },
        "claude-opus-4.5": {
          "options": {
            "textVerbosity": "medium"
          }
        },
        "claude-opus-4.6": {
          "options": {
            "textVerbosity": "medium"
          }
        },
        "claude-opus-4.7": {
          "options": {
