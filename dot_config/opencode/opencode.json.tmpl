          }
        },
        "gpt-5.3-codex": {
          "options": {
            "reasoningEffort": "medium",
            "textVerbosity": "low"
          },
          "variants": {
            "low": {
              "reasoningEffort": "low",
              "textVerbosity": "low"
            },
            "medium": {
              "reasoningEffort": "medium",
              "textVerbosity": "low"
            },
            "high": {
              "reasoningEffort": "high",
              "textVerbosity": "medium"
            }
          }
        },
        "claude-sonnet-4.6": {
          "options": {
            "textVerbosity": "low"
          }
        },
        "gemini-2.5-pro": {
          "options": {
            "textVerbosity": "high"
          }
