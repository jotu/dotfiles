          "options": {
            "textVerbosity": "low"
          }
        },
        "gpt-4.1": {
          "options": {
            "reasoningEffort": "medium",
            "textVerbosity": "low"
          }
        },
        "gpt-4o": {
          "options": {
            "textVerbosity": "low"
          }
        },
        "gpt-5-mini": {
          "options": {
            "reasoningEffort": "low",
            "textVerbosity": "low"
          },
          "variants": {
            "low": {
              "reasoningEffort": "low",
              "textVerbosity": "low"
            },
            "medium": {
              "reasoningEffort": "medium",
              "textVerbosity": "low"
            }
          }
        },
        "gpt-5.2-codex": {
          "options": {
            "reasoningEffort": "medium",
            "textVerbosity": "low"
          }
        },
        "gpt-5.2": {
          "options": {
            "reasoningEffort": "medium",
            "textVerbosity": "low"
          }
        },
        "gpt-5.4": {
          "options": {
            "reasoningEffort": "high",
            "textVerbosity": "medium"
          },
          "variants": {
            "medium": {
              "reasoningEffort": "medium",
              "textVerbosity": "low"
            },
            "high": {
              "reasoningEffort": "high",
              "textVerbosity": "medium"
            }
          }
        }
      }
    }
  },
  "compaction": {
    "tail_turns": 12
  },
  "$schema": "https://opencode.ai/config.json"
{{- else if or (eq $profile "work-copilot") (eq $profile "home-copilot") }}
